generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique
  password   String
  nombre     String?
  role       String   @default("ADMIN") // ADMIN o CLIENTE
  cliente_id String?  @unique @db.Uuid
  cliente    Cliente? @relation(fields: [cliente_id], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Cliente {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String
  apellido   String
  email      String?    @unique
  telefono   String?
  cedula     String?    @unique
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at DateTime?  @default(now()) @db.Timestamptz(6)
  prestamos  Prestamo[]
  user       User?

  @@map("clientes")
}

model Prestamo {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id        String    @db.Uuid
  monto_capital     Decimal   @db.Decimal(10, 2)
  tipo_interes      String    @db.VarChar
  valor_interes     Decimal   @db.Decimal(10, 2)
  monto_interes     Decimal   @db.Decimal(10, 2)
  total_adeudado    Decimal   @db.Decimal(10, 2)
  saldo_pendiente   Decimal   @db.Decimal(10, 2)
  estado            String    @db.VarChar
  fecha_creacion    DateTime? @default(now()) @db.Timestamptz(6)
  fecha_vencimiento DateTime? @db.Timestamptz(6)
  descripcion       String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  clientes          Cliente   @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pagos             Pago[]
  moras             Mora[]

  @@map("prestamos")
}

model Pago {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prestamo_id          String    @db.Uuid
  monto_pagado         Decimal   @db.Decimal(10, 2)
  monto_capital_pagado Decimal   @db.Decimal(10, 2)
  monto_interes_pagado Decimal   @db.Decimal(10, 2)
  monto_mora_pagado    Decimal   @default(0) @db.Decimal(10, 2)
  saldo_antes          Decimal?  @db.Decimal(10, 2)
  saldo_despues        Decimal?  @db.Decimal(10, 2)
  fecha_pago           DateTime  @db.Timestamptz(6)
  notas                String?
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  prestamos            Prestamo  @relation(fields: [prestamo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("pagos")
}

model Mora {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prestamo_id String   @db.Uuid
  monto_mora  Decimal  @db.Decimal(10, 2)
  razon       String
  pagada      Boolean  @default(false)
  fecha_mora  DateTime @db.Timestamptz(6)
  prestamos   Prestamo @relation(fields: [prestamo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("moras")
}
